{
  "name": "hawk-device-detection",
  "version": "1.0.0",
  "description": "Production-grade device detection and environment monitoring engine. Multi-layer detection for OS, device type, architecture, capabilities, and metadata.",
  "main": "src/hawk.js",
  "types": "src/hawk.d.ts",
  "scripts": {
    "test": "node test/hawk.test.js",
    "benchmark": "node benchmark/performance.js",
    "lint": "eslint src/ test/ benchmark/ --fix || true",
    "format": "prettier --write src/ test/ benchmark/ *.md",
    "prepublishOnly": "npm run test && npm run benchmark"
  },
  "keywords": [
    "device-detection",
    "environment-monitoring",
    "device-intelligence",
    "user-agent",
    "browser-detection",
    "os-detection",
    "device-type",
    "capabilities",
    "fingerprinting",
    "iot",
    "nodejs",
    "javascript",
    "cross-platform"
  ],
  "author": {
    "name": "Uviwe Menyiwe (Azura)",
    "email": "contact@haelfoundation.org",
    "url": "https://haelfoundation.org"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/haelfoundation/hawk.git"
  },
  "bugs": {
    "url": "https://github.com/haelfoundation/hawk/issues",
    "email": "contact@haelfoundation.org"
  },
  "homepage": "https://github.com/haelfoundation/hawk#readme",
  "files": [
    "src/",
    "test/",
    "benchmark/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=12.0.0"
  },
  "exports": {
    ".": {
      "require": "./src/hawk.js",
      "import": "./src/hawk.js"
    }
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {},
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/haelfoundation"
  }
}
